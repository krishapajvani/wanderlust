<% layout("/layouts/boilerplate") %>

<style>
    :root {
        --brand-red: #FF385C;
        --tech-charcoal: #222222;
        --soft-bg: #fdfdfd;
    }

    body { background-color: var(--soft-bg); }

    /* Hero Section */
    .careers-hero {
        padding: 100px 0;
        background: linear-gradient(rgba(0,0,0,0.6), rgba(0,0,0,0.6)), url('https://images.unsplash.com/photo-1522071820081-009f0129c71c?auto=format&fit=crop&w=1500&q=80');
        background-size: cover;
        background-position: center;
        color: white;
        border-radius: 0 0 50px 50px;
    }

    /* Culture Section */
    .value-card {
        border: none;
        background: white;
        padding: 40px;
        border-radius: 24px;
        box-shadow: 0 10px 30px rgba(0,0,0,0.05);
        height: 100%;
        transition: 0.3s;
    }

    .value-card:hover {
        transform: translateY(-10px);
        box-shadow: 0 15px 40px rgba(255, 56, 92, 0.1);
    }

    .value-icon {
        width: 60px;
        height: 60px;
        background: #fff1f3;
        color: var(--brand-red);
        border-radius: 15px;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 1.5rem;
        margin-bottom: 25px;
    }

    /* Jobs Table */
    .job-row {
        background: white;
        padding: 20px 30px;
        border-radius: 16px;
        margin-bottom: 15px;
        border: 1px solid #eee;
        transition: 0.2s;
        cursor: pointer;
    }

    .job-row:hover {
        border-color: var(--brand-red);
        background: #fffcfc;
    }

    .job-tag {
        font-size: 0.75rem;
        padding: 4px 12px;
        border-radius: 50px;
        background: #e9ecef;
        font-weight: 600;
    }

    .btn-apply {
        background: var(--tech-charcoal);
        color: white !important;
        border-radius: 10px;
        padding: 8px 20px;
        font-weight: 600;
        text-decoration: none;
    }

    .btn-apply:hover {
        background: var(--brand-red);
    }
</style>

<div class="careers-hero text-center">
    <div class="container">
        <h1 class="display-3 fw-bold mb-3">Build the future of travel.</h1>
        <p class="lead mb-4">Join our mission to create a world where anyone can belong anywhere.</p>
        <a href="#open-roles" class="btn btn-danger btn-lg rounded-pill px-5 fw-bold">See Open Roles</a>
    </div>
</div>

<div class="container my-5 py-5">
    <div class="text-center mb-5">
        <h2 class="fw-bold">Why work at Staycation?</h2>
        <p class="text-muted">We’re a team of travelers, designers, and engineers building the next generation of hospitality.</p>
    </div>

    <div class="row g-4">
        <div class="col-md-4">
            <div class="value-card text-center">
                <div class="value-icon mx-auto"><i class="fa-solid fa-bolt"></i></div>
                <h5 class="fw-bold">Fast-Paced Growth</h5>
                <p class="small text-muted mb-0">We’re expanding rapidly across India. Your work will impact thousands of travelers from day one.</p>
            </div>
        </div>
        <div class="col-md-4">
            <div class="value-card text-center">
                <div class="value-icon mx-auto"><i class="fa-solid fa-heart"></i></div>
                <h5 class="fw-bold">Remote-First Culture</h5>
                <p class="small text-muted mb-0">Whether you’re in Rajkot, Bangalore, or London—we believe in working where you’re most inspired.</p>
            </div>
        </div>
        <div class="col-md-4">
            <div class="value-card text-center">
                <div class="value-icon mx-auto"><i class="fa-solid fa-gift"></i></div>
                <h5 class="fw-bold">Travel Credits</h5>
                <p class="small text-muted mb-0">Every employee gets annual travel credits to experience our unique listings firsthand.</p>
            </div>
        </div>
    </div>

    <div id="open-roles" class="mt-5 pt-5">
        <div class="d-flex justify-content-between align-items-center mb-4">
            <h3 class="fw-bold">Open Roles</h3>
            <span class="text-muted fw-bold">5 Active Openings</span>
        </div>

        <div class="job-row d-flex align-items-center justify-content-between flex-wrap shadow-sm">
            <div>
                <h5 class="fw-bold mb-1">Full-Stack Web Developer</h5>
                <span class="job-tag me-2">Engineering</span>
                <span class="job-tag me-2"><i class="fa-solid fa-location-dot me-1"></i> Rajkot / Remote</span>
            </div>
            <div class="mt-3 mt-md-0">
                <a href="#" class="btn-apply">View Details</a>
            </div>
        </div>

        <div class="job-row d-flex align-items-center justify-content-between flex-wrap shadow-sm">
            <div>
                <h5 class="fw-bold mb-1">UI/UX Product Designer</h5>
                <span class="job-tag me-2">Design</span>
                <span class="job-tag me-2"><i class="fa-solid fa-location-dot me-1"></i> Remote</span>
            </div>
            <div class="mt-3 mt-md-0">
                <a href="#" class="btn-apply">View Details</a>
            </div>
        </div>

        <div class="job-row d-flex align-items-center justify-content-between flex-wrap shadow-sm">
            <div>
                <h5 class="fw-bold mb-1">Community Manager</h5>
                <span class="job-tag me-2">Marketing</span>
                <span class="job-tag me-2"><i class="fa-solid fa-location-dot me-1"></i> Mumbai</span>
            </div>
            <div class="mt-3 mt-md-0">
                <a href="#" class="btn-apply">View Details</a>
            </div>
        </div>
    </div>

    <div class="mt-5 p-5 rounded-4 text-center" style="background: #f1f3f5;">
        <h4 class="fw-bold">Don't see a perfect fit?</h4>
        <p class="text-muted">We’re always looking for talented people. Send us your resume anyway!</p>
        <a href="mailto:careers@staycation.com" class="text-danger fw-bold text-decoration-none">Drop your CV here →</a>
    </div>
</div>