<% layout("/layouts/boilerplate") %>

<style>
    :root {
        --brand-red: #FF385C;
        --text-dark: #222222;
        --text-light: #717171;
    }

    .aircover-hero {
        padding: 80px 0;
        background: #fff;
        text-align: center;
    }

    .aircover-logo {
        font-weight: 900;
        font-size: 3.5rem;
        letter-spacing: -2px;
        color: var(--text-dark);
        margin-bottom: 20px;
    }

    .aircover-logo span {
        color: var(--brand-red);
    }

    .aircover-card {
        border: none;
        border-radius: 24px;
        padding: 40px;
        background: #ffffff;
        box-shadow: 0 10px 30px rgba(0,0,0,0.05);
        height: 100%;
        transition: transform 0.3s ease;
    }

    .aircover-card:hover {
        transform: translateY(-5px);
    }

    .feature-icon {
        font-size: 2.5rem;
        color: var(--brand-red);
        margin-bottom: 20px;
    }

    .protection-badge {
        background-color: #f7f7f7;
        border-radius: 50px;
        padding: 15px 30px;
        display: inline-flex;
        align-items: center;
        font-weight: 700;
        margin-top: 40px;
    }

    .protection-badge i {
        color: #00A699; /* Airbnb Safety Green */
        margin-right: 10px;
    }

    .comparison-table {
        background: white;
        border-radius: 24px;
        overflow: hidden;
        border: 1px solid #eee;
    }

    .comparison-table th {
        background: #f7f7f7;
        padding: 20px;
        font-weight: 700;
    }

    .comparison-table td {
        padding: 20px;
        border-bottom: 1px solid #eee;
    }

    @media (max-width: 768px) {
        .aircover-logo { font-size: 2.5rem; }
    }
</style>

<div class="aircover-hero">
    <div class="container">
        <h1 class="aircover-logo">air<span>cover</span></h1>
        <p class="lead fw-bold text-dark">Top-to-bottom protection. Free for every guest.</p>
        <p class="text-muted mx-auto" style="max-width: 600px;">
            Staycation provides the most comprehensive protection in travel. Every booking includes protection from Host cancellations, listing inaccuracies, and other issues like check-in problems.
        </p>
    </div>
</div>

<div class="container mb-5">
    <div class="row g-4">
        <div class="col-md-3">
            <div class="aircover-card">
                <i class="fa-solid fa-calendar-xmark feature-icon"></i>
                <h5 class="fw-bold">Booking Protection</h5>
                <p class="small text-muted">In the unlikely event a Host needs to cancel your booking within 30 days of check-in, we’ll find you a similar or better home, or we’ll refund you.</p>
            </div>
        </div>

        <div class="col-md-3">
            <div class="aircover-card">
                <i class="fa-solid fa-key feature-icon"></i>
                <h5 class="fw-bold">Check-In Guarantee</h5>
                <p class="small text-muted">If you can’t get into your home and the Host can’t resolve the issue, we’ll find you a similar or better home for the length of your original stay, or we’ll refund you.</p>
            </div>
        </div>

        <div class="col-md-3">
            <div class="aircover-card">
                <i class="fa-solid fa-circle-check feature-icon"></i>
                <h5 class="fw-bold">Get-What-You-Booked</h5>
                <p class="small text-muted">If at any time during your stay you find your listing isn't as advertised—for example, the fridge stops working and your Host can’t easily fix it—we’ll help find a better home.</p>
            </div>
        </div>

        <div class="col-md-3">
            <div class="aircover-card">
                <i class="fa-solid fa-headset feature-icon"></i>
                <h5 class="fw-bold">24-hour Safety Line</h5>
                <p class="small text-muted">If you ever feel unsafe, you’ll get priority access to specially trained safety agents, day or night, right here in Rajkot or wherever you are.</p>
            </div>
        </div>
    </div>

    <div class="text-center">
        <div class="protection-badge shadow-sm">
            <i class="fa-solid fa-shield-check"></i>
            Included for free on every booking.
        </div>
    </div>

    <div class="mt-5 py-5">
        <h2 class="fw-bold mb-4 text-center">How AirCover compares</h2>
        <div class="comparison-table shadow-sm">
            <table class="w-100">
                <thead>
                    <tr>
                        <th>Protection</th>
                        <th class="text-center">Staycation AirCover</th>
                        <th class="text-center text-muted">Competitors</th>
                    </tr>
                </thead>
                <tbody>
                    <tr>
                        <td>Host Cancellation Protection</td>
                        <td class="text-center text-success"><i class="fa-solid fa-check"></i></td>
                        <td class="text-center text-muted"><i class="fa-solid fa-minus"></i></td>
                    </tr>
                    <tr>
                        <td>Check-In Guarantee</td>
                        <td class="text-center text-success"><i class="fa-solid fa-check"></i></td>
                        <td class="text-center text-muted"><i class="fa-solid fa-minus"></i></td>
                    </tr>
                    <tr>
                        <td>Listing Inaccuracy Protection</td>
                        <td class="text-center text-success"><i class="fa-solid fa-check"></i></td>
                        <td class="text-center text-muted"><i class="fa-solid fa-minus"></i></td>
                    </tr>
                    <tr>
                        <td>24-Hour Safety Line</td>
                        <td class="text-center text-success"><i class="fa-solid fa-check"></i></td>
                        <td class="text-center text-muted"><i class="fa-solid fa-minus"></i></td>
                    </tr>
                </tbody>
            </table>
        </div>
    </div>
</div>

<div class="bg-light py-5 text-center mt-5">
    <div class="container">
        <h4 class="fw-bold">Find answers to your questions</h4>
        <p class="text-muted">Visit our Help Centre to learn more about AirCover and other protections.</p>
        <a href="/help" class="btn btn-dark rounded-pill px-4 fw-bold">Go to Help Centre</a>
    </div>
</div>